# tsp-qc1.1 container build: the PRIVATE platform repo is vendored into the build context as a
# pinned `git archive` (docker/platform.pin records repo+commit). It is a build INPUT, not source —
# never commit it (same model as vendor blobs / wifi.txt). Must still reach `docker build`.
platform-pinned.tar
# Build outputs + vendored upstream clones (all reproducible from pins).
sdl3/build/
harness/build/
**/build/
SDL/
# editor / OS noise
*.o
*.swp
.DS_Store
# tsp-an4.4 fb: regenerable artifacts
*.ppm
fb/build.log
__pycache__/
*.pyc
# tsp-an4.5 control: per-launcher working dirs (PPMs, FIFOs, app logs) are regenerable.
# Keep only baseline/<dev>/*.png + baseline/RESULTS.md.
control/baseline/*/native/
control/baseline/*/qemu/
# tsp-an4.6 skin: per-launcher working dirs (PPMs, scenes, frames, body/lit PPMs) are regenerable.
# Keep only skin/baseline/<dev>/avd_*.png + skin/baseline/RESULTS.md. The built renderer too.
skin/baseline/*/native/
skin/baseline/*/qemu/
skin/skin-render
# tsp-an4.7 sensor: per-launcher working dirs (synth IIO trees, FIFOs, app logs) are regenerable.
# Keep only sensor/baseline/sensor-evidence.json + sensor/baseline/RESULTS.md.
sensor/baseline/*/native/
sensor/baseline/*/qemu/
